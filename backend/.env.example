# Backend environment variables
# Copy this file to .env and fill in the values

APP_ENV=development
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Legacy fallback model used when the split vars below are not set.
ANTHROPIC_MODEL=claude-opus-4-7

# Recommended explicit model config.
ANTHROPIC_MODEL_PARSE=claude-opus-4-7
ANTHROPIC_MODEL_TRANSCRIBE=claude-opus-4-7

BUNQ_API_KEY=your_bunq_api_key_here
